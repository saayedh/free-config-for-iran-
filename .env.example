# ═══════════════════════════════════════════════════════
# TGBot Collector — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────
ENVIRONMENT=production          # development | staging | production
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                 # json | console
DEBUG=false

# ─── Database (PostgreSQL) ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tgbot
DB_USER=tgbot
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── Telegram ────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi
# Your personal chat ID — receive admin alerts here
TELEGRAM_ADMIN_CHAT_ID=123456789
TELEGRAM_REQUEST_TIMEOUT=30
TELEGRAM_MAX_RETRIES=5
TELEGRAM_PARSE_MODE=HTML        # HTML | MarkdownV2

# ─── Collector ───────────────────────────────────────────
COLLECTOR_DEFAULT_TIMEOUT=30
COLLECTOR_MAX_CONCURRENT=10
COLLECTOR_RETRY_ATTEMPTS=3

# ─── Scheduler (cron syntax) ─────────────────────────────
SCHEDULER_COLLECTION_CRON=0 */2 * * *
SCHEDULER_PUBLISHING_CRON=*/30 * * * *
SCHEDULER_HEALTHCHECK_CRON=*/15 * * * *
SCHEDULER_CLEANUP_CRON=0 3 * * *
SCHEDULER_TIMEZONE=UTC

# ─── Quality Scoring ─────────────────────────────────────
SCORING_FRESHNESS_WEIGHT=0.35
SCORING_COMPLETENESS_WEIGHT=0.25
SCORING_SOURCE_RELIABILITY_WEIGHT=0.25
SCORING_VALIDATION_WEIGHT=0.15
SCORING_MIN_PUBLISHABLE_SCORE=40.0
SCORING_FRESHNESS_DECAY_HOURS=72

# ─── Monitoring ──────────────────────────────────────────
MONITORING_ALERT_ON_CONSECUTIVE_FAILURES=3
MONITORING_PROMETHEUS_PORT=9090
MONITORING_ENABLE_PROMETHEUS=true
